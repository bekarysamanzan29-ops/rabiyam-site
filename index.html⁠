<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Для Рабиюши 💝</title>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.2/dist/confetti.browser.min.js"></script>
    <style>
        body { font-family: 'Poppins', sans-serif; background: #fff0f5; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; }
        .glass-card { background: white; padding: 30px; border-radius: 25px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); text-align: center; max-width: 400px; width: 90%; }
        .photo-box img { width: 100%; border-radius: 15px; margin-bottom: 20px; }
        h1 { color: #d63384; }
        .buttons { display: flex; gap: 15px; justify-content: center; margin-top: 20px; }
        button { padding: 10px 20px; border: none; border-radius: 15px; cursor: pointer; font-weight: bold; }
        #yesBtn { background: #ff4d6d; color: white; }
        #noBtn { background: #ccc; color: #333; position: absolute; }
    </style>
</head>
<body>

<div class="glass-card" id="mainPage">
    <div class="photo-box">
        <!-- Твои файлы, которые уже есть в репозитории -->
        <img src="1.jpg" alt="Мы">
    </div>
    <h1>Милая Рабиюша 💝</h1>
    <h2>Абдрахимова Рабиям Пархатовна</h2>
    <p class="question">10 июля пойдешь ли ты со мной на свиданку-гулянку? 💘</p>
    
    <div class="buttons" id="btn-container" style="height: 50px;">
        <button id="yesBtn" onclick="confettiFunction()">💝 Конечно пойду</button>
        <button id="noBtn" onmouseover="moveNo()">Неа</button>
    </div>
</div>

<script>
    function confettiFunction() {
        confetti({ particleCount: 150, spread: 80, origin: { y: 0.6 } });
        alert("Ура! Тогда обсудим время! 🥰");
    }
    function moveNo() {
        const btn = document.getElementById('noBtn');
        const container = document.getElementById('btn-container');
        btn.style.left = (Math.random() * 200 - 100) + 'px';
        btn.style.top = (Math.random() * 100 - 50) + 'px';
    }
</script>

</body>
</html>
